# Dev-server port. Each worktree runs on its own port (3000 = main, 3001+ = worktrees).
PORT=3000

# QA scoring provider selection.
#   mock = deterministic faker output (default; used by seed + CI)
#   llm  = real LLM call via @anthropic-ai/sdk
LLM_SCORING_PROVIDER=mock

# API key for the configured LLM. Required when LLM_SCORING_PROVIDER=llm.
# Local-only; never commit the real value.
LLM_API_KEY=

# Model identifier passed to the LLM SDK. The default is Anthropic's current
# flagship; the env var is named generically because the prototype's surface
# treats the LLM as an interchangeable component.
LLM_MODEL=claude-opus-4-7

# Logo provider for workspace logos (Settings > Workspace > Logo).
#   brandfetch (default) — pulls from cdn.brandfetch.io; requires a free
#                          clientId registered at developers.brandfetch.com.
LOGO_PROVIDER=brandfetch
BRANDFETCH_CLIENT_ID=

# WorkOS AuthKit. Issued by the WorkOS dashboard for this app's environment.
# `WORKOS_COOKIE_PASSWORD` must be a 32+ char random string (used to seal the
# session cookie). The redirect URI must be registered in the WorkOS dashboard
# and match this app's running origin + `/callback`.
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
