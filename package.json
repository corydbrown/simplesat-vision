{
  "name": "simplesat-vision",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port \"$(grep -hs '^PORT=' .env.local 2>/dev/null | tail -n1 | cut -d= -f2 | tr -d ' \"' | grep -E '^[0-9]+$' || echo 3000)\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx --conditions=react-server src/db/seed.ts && npm run avatars:generate",
    "db:studio": "drizzle-kit studio",
    "db:reset": "rm -f db/simplesat.db db/simplesat.db-shm db/simplesat.db-wal && npm run db:migrate && npm run db:seed",
    "avatars:generate": "tsx --conditions=react-server scripts/generate-avatars.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@dicebear/avataaars": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@dicebear/croodles-neutral": "^9.4.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@faker-js/faker": "^10.4.0",
    "@libsql/client": "^0.15.4",
    "@tanstack/react-table": "^8.21.3",
    "@workos-inc/authkit-nextjs": "^4.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.16.0",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "csv-parse": "^6.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.1",
    "typescript": "^5"
  }
}
